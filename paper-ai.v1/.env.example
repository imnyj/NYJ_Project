# ────────────────────────────────────────────────────────────────────────────
# paper-ai .env example — six-agent layout
# ────────────────────────────────────────────────────────────────────────────
# Copy this to `.env` (same directory) and fill in your six API keys, OR
# encrypt them with `python encrypt_key.py --key-name ANTHROPIC_API_KEY_<ROLE>`
# in which case each line will read `ENC:gAAAA...` instead of plain text.
#
# After encrypting, verify with `python -m secrets_tool verify` (expect
# "6 ok, 0 failed").
#
# ────────────────────────────────────────────────────────────────────────────
# Six canonical roles
# ────────────────────────────────────────────────────────────────────────────
# Each role gets ITS OWN distinct API key. This lets you track per-agent
# token consumption in the Anthropic console and rotate keys independently
# (e.g. revoke just Writer's key if you suspect leakage).

ANTHROPIC_API_KEY_COMMANDER=sk-ant-...
ANTHROPIC_API_KEY_LIBRARIAN=sk-ant-...
ANTHROPIC_API_KEY_IDEA=sk-ant-...
ANTHROPIC_API_KEY_EXPERIMENTER=sk-ant-...
ANTHROPIC_API_KEY_REVIEWER=sk-ant-...
ANTHROPIC_API_KEY_WRITER=sk-ant-...

# ────────────────────────────────────────────────────────────────────────────
# Legacy alias support (optional)
# ────────────────────────────────────────────────────────────────────────────
# If you're migrating from the original 8-agent layout and have keys named
# CODER / EXPERIMENT / VISUALIZATION / VALIDATOR / PROOFREADER, those are
# still recognised as aliases. The first matching key wins:
#
#   role          → fallback chain
#   ───────────────────────────────────────────────────────────────────────
#   experimenter  → EXPERIMENTER, EXPERIMENT, CODER, VISUALIZATION
#   reviewer      → REVIEWER, VALIDATOR, PROOFREADER
#
# So either canonical 6-key layout above OR your existing 8-key .env works.

# Optional legacy keys — uncomment if you want sub-role tracking even
# though all three roles share one model alias:
# ANTHROPIC_API_KEY_CODER=sk-ant-...
# ANTHROPIC_API_KEY_EXPERIMENT=sk-ant-...
# ANTHROPIC_API_KEY_VISUALIZATION=sk-ant-...
# ANTHROPIC_API_KEY_VALIDATOR=sk-ant-...
# ANTHROPIC_API_KEY_PROOFREADER=sk-ant-...

# ────────────────────────────────────────────────────────────────────────────
# Optional: working directory for paper artefacts
# ────────────────────────────────────────────────────────────────────────────
# Where Commander writes .pipeline/, paper/, figure/, graph/, photo/.
# Default: PAPER_AI_ROOT/workspace (i.e. inside the code base).
# Override to e.g. /home/you/0_paper to keep code and artefacts separate.

# PAPER_BASE_DIR=/home/you/0_paper

# ────────────────────────────────────────────────────────────────────────────
# Optional: smolagents runtime knobs
# ────────────────────────────────────────────────────────────────────────────
# MAX_STEPS=25       # ReAct steps per agent.run() call
# MAX_RETRIES=10     # Reviewer FAIL → Experimenter[implement] retry cap

# ────────────────────────────────────────────────────────────────────────────
# Optional: Semantic Scholar API (for Librarian)
# ────────────────────────────────────────────────────────────────────────────
# Without this the public endpoint works but is rate-limited (1 req/sec).
# SEMANTIC_SCHOLAR_API_KEY=...
