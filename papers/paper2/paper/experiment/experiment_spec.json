    "S2_cache_average_aoi.csv",
    "S2_cache_peak_aoi.csv",
    "S2_cache_cache_hit_ratio.csv",
    "S2_cache_tx_success_rate.csv",
    "S3_channel_average_aoi.csv",
    "S3_channel_peak_aoi.csv",
    "S3_channel_tx_success_rate.csv",
    "S3_channel_throughput.csv",
    "S4_zipf_average_aoi.csv",
    "S4_zipf_cache_hit_ratio.csv",
    "convergence_training_curves.csv",
    "convergence_constraint_satisfaction.csv",
    "ablation_component_analysis.csv",
    "communication_overhead.csv",
