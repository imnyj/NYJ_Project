  "experiment_phases": {
    "phase1_model_verification": {
      "description": "Validate Theorem 1 (AoI Reduction Bound) and Theorem 2 (Optimal TTL) against simulation",
      "output": [
        "model_verification_theorem1.csv",
        "model_verification_theorem2.csv"
      ]
    },
    "phase2_convergence": {
